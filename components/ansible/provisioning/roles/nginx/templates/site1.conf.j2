upstream backend_app {
    # The actual Docker container running on the same host
    # using the default bridge network IP or localhost if exposed
    server 127.0.0.1:8080;
}

server {
    listen 80;
    server_name {{ env_name }}.myatminsoe.com;

    access_log /var/log/nginx/{{ env_name }}_site1_access.log;
    error_log /var/log/nginx/{{ env_name }}_site1_error.log;

    location / {
        proxy_pass http://backend_app;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support if needed
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
